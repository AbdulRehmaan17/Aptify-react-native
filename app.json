{
  "expo": {
    "name": "Aptify",
    "slug": "aptify-mobile",
    "owner": "abdulrehmaan17",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "aptify",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aptify.mobile",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.aptify.mobile",
      "versionCode": 1
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "your-project-id"
      },
      "router": {
        "origin": false
      }
    }
  }
}