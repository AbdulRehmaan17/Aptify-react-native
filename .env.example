# Firebase Configuration
# Get these values from Firebase Console â†’ Project Settings â†’ General â†’ Your apps
# Copy the config object values (not the web app config)
EXPO_PUBLIC_FIREBASE_API_KEY=your-api-key-here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id-here
EXPO_PUBLIC_FIREBASE_APP_ID=your-app-id-here

# Google OAuth Configuration
# Get this from Google Cloud Console â†’ APIs & Services â†’ Credentials
# Create OAuth 2.0 Client ID (Web application type)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com

# Instructions:
# 1. Copy this file to .env (without .example)
# 2. Replace all placeholder values with your actual values
# 3. Restart your Expo development server after making changes
# 4. Never commit .env to version control (it's in .gitignore)
